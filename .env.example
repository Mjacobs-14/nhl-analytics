# Copy to .env and fill in. Never commit the real values.

# Postgres connection string — used by the Next.js app and the scripts/ pipeline.
# Supabase: Project Settings > Database > Connection string (URI). Either the
# direct connection (port 5432) or the transaction pooler (port 6543) works.
# Any plain Postgres works too (e.g. a local one for hacking offline).
DATABASE_URL=postgresql://postgres:YOUR-PASSWORD@db.xxxx.supabase.co:5432/postgres

# Used only by the Python daily ETL (etl/pull_nhl_data.py). In GitHub Actions
# these come from repo secrets instead — see .github/workflows/etl.yml.
# Supabase: Project Settings > API (use the service_role key, not anon).
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=your-service-role-key
